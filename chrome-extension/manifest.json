{
  "manifest_version": 3,
  "name": "Project Tracker",
  "version": "1.0.0",
  "description": "UX/UI time tracking for designers — by project and phase",
  "permissions": ["storage", "idle", "alarms"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Project Tracker"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
